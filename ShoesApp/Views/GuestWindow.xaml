<Window x:Class="ShoesApp.Views.GuestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ShoesApp.Views"
        xmlns:vm="clr-namespace:ShoesApp.ViewModels"
        mc:Ignorable="d"
        Title="GuestWindow" Height="450" Width="800">
    <Window.DataContext>
        <vm:GuestViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" Width="40" Height="40" Source="/Resources/icon.png"/>
                
                <TextBlock Grid.Column="1" Text="ООО МирИгрушек - Гость"/>
                
                <Button 
                    Grid.Column="2" 
                    Content="Выйти"
                    Command="{Binding LogoutCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    />
            </Grid>
        </Border>
        
        <DataGrid Grid.Row="1" ItemsSource="{Binding Products}">
            
        </DataGrid>
    </Grid>
</Window>
