<Window x:Class="ShoesApp.Views.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ShoesApp.Views"
        mc:Ignorable="d"
        Title="ManagerWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" Width="40" Height="40" Source="/Resources/icon.png"/>
                
                <TextBlock Grid.Column="1" Text="ООО МирИгрушек -  Менеджер"/>
                <TextBlock Grid.Column="2" Text="{Binding CurrentUserName}"/>
                
                <Button 
                    Grid.Column="3" 
                    Content="Выйти"
                    Command="{Binding LogoutCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                />
            </Grid>
        </Border>
        
        <TabControl Grid.Row="1">
            <TabItem Header="Товары">
                <DataGrid ItemsSource="{Binding Products}">
            
                </DataGrid>
            </TabItem>
            <TabItem Header="Заказы">
                <DataGrid ItemsSource="{Binding Orders}">
            
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
